use assert_cmd::Command;

#[test]
fn version_prints_highharness_0_1_0() {
    let stdout = Command::cargo_bin("HighHarness").unwrap()
        .arg("--version")
        .output()
        .unwrap()
        .stdout;
    let s = String::from_utf8(stdout).unwrap();
    assert_eq!(s, "HighHarness 0.1.0\n");
}
